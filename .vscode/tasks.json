{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake: configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "${input:preset}"
            ]
        },
        {
            "label": "cmake: build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "${input:preset}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": ["cmake: configure"],
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "preset",
            "type": "pickString",
            "description": "Select CMake preset",
            "options": [
                "linux-debug",
                "linux-release",
                "linux-relwithdebinfo",
                "windows-debug",
                "windows-release",
                "windows-relwithdebinfo"
            ],
            "default": "linux-debug"
        }
    ]
}